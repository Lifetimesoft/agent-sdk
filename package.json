{
  "name": "@lifetimesoft/agent-sdk",
  "version": "0.1.0",
  "description": "Lightweight SDK for building portable AI agents that run on the LifetimeSoft platform",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing.d.ts",
      "import": "./dist/testing.mjs",
      "require": "./dist/testing.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src tests",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "ai",
    "agent",
    "sdk",
    "lifetimesoft"
  ],
  "author": "LifetimeSoft",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lifetimesoft/agent-sdk.git"
  },
  "homepage": "https://github.com/Lifetimesoft/agent-sdk#readme",
  "bugs": {
    "url": "https://github.com/Lifetimesoft/agent-sdk/issues"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^3.2.0"
  }
}
