{
    "name": "@lifetimesoft/agent-sdk",
    "version": "0.0.1",
    "description": "Lightweight SDK for building portable AI agents that run on the LifetimeSoft platform",
    "main": "dist/index.js",
    "module": "dist/index.mjs",
    "types": "dist/index.d.ts",
    "bin": {
        "agent-runtime": "dist/runtime.js"
    },
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        },
        "./testing": {
            "types": "./dist/testing.d.ts",
            "import": "./dist/testing.mjs",
            "require": "./dist/testing.js"
        },
        "./runtime": {
            "types": "./dist/runtime.d.ts",
            "import": "./dist/runtime.mjs",
            "require": "./dist/runtime.js"
        }
    },
    "files": [
        "dist",
        "README.md",
        "LICENSE"
    ],
    "engines": {
        "node": ">=18"
    },
    "sideEffects": false,
    "scripts": {
        "build": "tsup",
        "dev": "tsup --watch",
        "typecheck": "tsc --noEmit",
        "lint": "eslint src tests",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage"
    },
    "keywords": [
        "ai",
        "agent",
        "sdk",
        "lifetimesoft"
    ],
    "author": "LifetimeSoft <admin@lifetimesoft.com>",
    "license": "Apache-2.0",
    "repository": {
        "type": "git",
        "url": "https://github.com/Lifetimesoft/agent-sdk.git"
    },
    "homepage": "https://github.com/Lifetimesoft/agent-sdk#readme",
    "bugs": {
        "url": "https://github.com/Lifetimesoft/agent-sdk/issues"
    },
    "devDependencies": {
        "@eslint/js": "9.39.4",
        "@types/node": "22.15.21",
        "eslint": "9.39.4",
        "tsup": "8.5.1",
        "typescript": "5.9.3",
        "typescript-eslint": "8.58.2",
        "vitest": "3.2.4"
    }
}
